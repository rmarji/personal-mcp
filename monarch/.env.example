# Monarch Money credentials — set these in the Coolify UI (Environment Variables tab)
# and NOT in this file. This is a template only.

MONARCH_EMAIL=you@example.com
MONARCH_PASSWORD=your-monarch-password
# Base32 TOTP secret from the Monarch MFA setup QR code.
# Extract with any TOTP scanner app, or from Monarch's "secret key" field.
MONARCH_MFA_SECRET=JBSWY3DPEHPK3PXP
